# ----------------------------- #
#  ⚙️  CONFIG GÉNÉRALE
# ----------------------------- #

# Hôte/port exposés par Express (Render injecte PORT automatiquement)
HOST=0.0.0.0
PORT=5000

# Environnement : development | production | test
NODE_ENV=development

# URL publique de l’API (mise à jour après déploiement)
PUBLIC_API_URL=http://localhost:5000

# URL du front (utilisée par CORS simple, CSP, etc.)
# En prod, mettre : https://<ton-front>.vercel.app
FRONTEND_URL=http://localhost:5173

# middleware CORS strict (liste blanche, virgules)
# Exemple prod : https://<ton-front>.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ----------------------------- #
#  🗄️  BASE DE DONNÉES MongoDB
# ----------------------------- #

# URI Atlas (prod) OU locale (dev). Remplace les <…> si Atlas.
# Exemple Atlas :
# MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/ahmi?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/ahmi-dev

# URI dédiée aux tests (Vitest/Jest/Supertest)
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/ahmi_test

# ----------------------------- #
#  🔐  JSON WEB TOKENS
# ----------------------------- #

# Clés secrètes – 
JWT_SECRET=__change_me_long_random__
JWT_REFRESH_SECRET=__change_me_long_random__

# Durées de validité
TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ----------------------------- #
#  ✉️  SMTP (Nodemailer)
# ----------------------------- #
# Dev (Mailtrap) : host sandbox, port 2525, secure=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_user
SMTP_PASS=your_password
SMTP_FROM="AHMI <no-reply@ahmi.fr>"

# ----------------------------- #
#  💳  STRIPE (facultatif – e-commerce à venir)
# ----------------------------- #
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------- #
#  🖼️  CLOUDINARY (facultatif – images)
# ----------------------------- #
# CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>

# ----------------------------- #
#  📚  OPENAPI / DOCS
# ----------------------------- #
OPENAPI_SPEC_PATH=../../docs/openapi.yaml
