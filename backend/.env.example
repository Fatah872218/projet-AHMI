# ----------------------------- #
#  ⚙️  CONFIG GÉNÉRALE
# ----------------------------- #

# Port HTTP du serveur Express
PORT=5000

# Environnement : development | production | test
NODE_ENV=development

# URL publique de l’API (à ajuster au déploiement)
BASE_URL=http://localhost:${PORT}

# URL du front (CORS). À changer quand tu déploieras (ex. https://ahmi.vercel.app)
FRONTEND_URL=http://localhost:5173

# ----------------------------- #
#  🗄️  BASE DE DONNÉES MongoDB
# ----------------------------- #

# URI Atlas ou locale : REMPLACE les <…> 
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/ahmi?retryWrites=true&w=majority

# URI dédiée aux tests (Vitest/Jest/Supertest)
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/ahmi_test

# ----------------------------- #
#  🔐  JSON WEB TOKENS
# ----------------------------- #

# Clés secrètes – génère-les en prod (openssl rand -hex 32)
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_too
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173

# Durées de validité
#   1h pour l’accès, 7d pour le refresh : à ajuster si besoin
TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ----------------------------- #
#  ✉️  SMTP (Nodemailer)
# ----------------------------- #

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true          # true si port 465 (SSL), false si 587 (STARTTLS)
SMTP_USER=your_user
SMTP_PASS=your_password
SMTP_FROM="AHMI <no-reply@ahmi.fr>"

# ----------------------------- #
#  💳  STRIPE (facultatif – e-commerce à venir)
# ----------------------------- #

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----------------------------- #
#  🖼️  CLOUDINARY (facultatif – images)
# ----------------------------- #
# Pour utiliser Cloudinary JS/Node :
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>

# ----------------------------- #
#  🔧  VARIABLES APP SPÉCIFIQUES
# ----------------------------- #
# variable métier (ex. MAX_FILE_SIZE, BASE_PATH, etc.)
