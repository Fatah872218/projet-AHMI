{
  "name": "backend",
  "version": "1.0.0",
  "description": "Ce dossier contient l’API REST du projet **AHMI**, développée en Node.js avec Express et MongoDB.",
  "main": "src/app.js",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=18 <21"
  },
  "scripts": {
    "test": "node -e \"process.exit(0)\"",
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "seed:user": "node src/scripts/createUser.cjs",
    "migrate:lieu": "node ./src/scripts/migrateLieuAdresse.js",
    "clean:adresse": "node ./src/scripts/removeAdresseFromLieu.js",
    "lint": "eslint \"src/**/*.{js,mjs,cjs}\"",
    "lint:fix": "eslint \"src/**/*.{js,mjs,cjs}\" --fix",
    "lint:ci": "eslint \"src/**/*.{js,mjs,cjs}\" --max-warnings=0",
    "build": "echo \"(backend) pas de build requis pour Express\"",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "argon2": "^0.41.1",
    "axios": "^1.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.2",
    "nodemailer": "^6.10.1",
    "sanitize-html": "^2.17.0",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.15",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "8.57.0"
  }
}
